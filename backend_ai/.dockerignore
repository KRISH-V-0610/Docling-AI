# The backend_ai image builds from the REPO ROOT (context: .), so without this
# it would copy the entire monorepo — frontend, node_modules, .git, the lot.
# Exclude everything that doesn't belong in the Python service image.
.git
.env
.env.*

# Frontend is built + deployed separately — never goes in the Python image.
frontend
node_modules

# NGINX config is mounted into its own container, not baked here.
nginx

# Python noise + local data/caches.
**/__pycache__
*.pyc
*.pyo
**/*.db
backend_ai/data/documents_store
backend_ai/deepscan/output

# The Node backend has its own image.
backend/node_modules
