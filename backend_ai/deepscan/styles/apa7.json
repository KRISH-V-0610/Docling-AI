{
  "style_name": "APA 7th Edition",
  "style_id": "apa7",
  "csl_style": "apa",

  "page_layout": {
    "margin_top_inches": 1.0,
    "margin_bottom_inches": 1.0,
    "margin_left_inches": 1.0,
    "margin_right_inches": 1.0,
    "page_width_inches": 8.5,
    "page_height_inches": 11.0,
    "orientation": "portrait"
  },

  "default_typography": {
    "font_name": "Times New Roman",
    "font_size_pt": 12.0,
    "line_spacing": 2.0,
    "line_spacing_type": "double",
    "paragraph_alignment": "left",
    "first_line_indent_inches": 0.5,
    "space_after_paragraph_pt": 0.0,
    "space_before_paragraph_pt": 0.0
  },

  "title_page": {
    "required": true,
    "title": {
      "font_size_pt": 12.0,
      "bold": true,
      "italic": false,
      "alignment": "center",
      "position": "3-4 lines below top margin"
    },
    "author_name": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center",
      "position": "one double-spaced line below title"
    },
    "affiliation": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center"
    },
    "course_info": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center"
    },
    "instructor": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center"
    },
    "date": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center"
    }
  },

  "abstract": {
    "label": "Abstract",
    "label_bold": true,
    "label_alignment": "center",
    "paragraph_indent": false,
    "max_words": 250,
    "keywords_label": "Keywords:",
    "keywords_italic": true,
    "keywords_indent": true
  },

  "headings": {
    "level_1": {
      "alignment": "center",
      "bold": true,
      "italic": false,
      "font_size_pt": 12.0,
      "case": "title_case",
      "standalone_line": true,
      "ends_with_period": false,
      "indent_inches": null,
      "description": "Centered, Bold, Title Case"
    },
    "level_2": {
      "alignment": "left",
      "bold": true,
      "italic": false,
      "font_size_pt": 12.0,
      "case": "title_case",
      "standalone_line": true,
      "ends_with_period": false,
      "indent_inches": null,
      "description": "Flush Left, Bold, Title Case"
    },
    "level_3": {
      "alignment": "left",
      "bold": true,
      "italic": true,
      "font_size_pt": 12.0,
      "case": "title_case",
      "standalone_line": true,
      "ends_with_period": false,
      "indent_inches": null,
      "description": "Flush Left, Bold Italic, Title Case"
    },
    "level_4": {
      "alignment": "indented",
      "bold": true,
      "italic": false,
      "font_size_pt": 12.0,
      "case": "title_case",
      "standalone_line": false,
      "ends_with_period": true,
      "indent_inches": 0.5,
      "description": "Indented 0.5in, Bold, Title Case, Period. Text on same line."
    },
    "level_5": {
      "alignment": "indented",
      "bold": true,
      "italic": true,
      "font_size_pt": 12.0,
      "case": "title_case",
      "standalone_line": false,
      "ends_with_period": true,
      "indent_inches": 0.5,
      "description": "Indented 0.5in, Bold Italic, Title Case, Period. Text on same line."
    }
  },

  "running_head": {
    "enabled": false,
    "content": "SHORTENED TITLE",
    "alignment": "left",
    "page_number_alignment": "right",
    "font_size_pt": 12.0,
    "all_caps": true,
    "max_characters": 50
  },

  "references": {
    "section_label": "References",
    "label_bold": true,
    "label_alignment": "center",
    "entry_indent_type": "hanging",
    "hanging_indent_inches": 0.5,
    "order": "alphabetical_by_first_author",
    "line_spacing": 2.0,
    "csl_style_name": "apa"
  },

  "tables": {
    "number_label": "Table",
    "number_bold": true,
    "number_italic": false,
    "title_italic": true,
    "title_below_number": true,
    "note_prefix": "Note.",
    "note_italic_prefix": true,
    "horizontal_lines_only": true
  },

  "figures": {
    "number_label": "Figure",
    "number_bold": true,
    "number_italic": true,
    "title_italic": true,
    "title_below_number": true,
    "note_prefix": "Note.",
    "note_italic_prefix": true
  },

  "in_text_citations": {
    "style": "author-date",
    "parenthetical_format": "(Author, Year)",
    "narrative_format": "Author (Year)",
    "et_al_threshold": 3,
    "ampersand_in_parenthetical": true,
    "and_in_narrative": true
  }
}
