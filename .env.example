# =============================================================================
# HackaMineD / Docling AI — root .env.example
# =============================================================================
# Two services share these vars:
#   - backend/      (Node/Express, port 3000)
#   - backend_ai/   (Python/FastAPI, port 8000) — chatbot + reconstruct +
#                   deepscan + file-editor + readme-gen
#
# Copy to backend/.env and backend_ai/.env (or one root .env when running
# via docker compose). Never commit real secrets.
# =============================================================================

# ── Express backend (backend/) ───────────────────────────────────────────────
PORT=3000
MONGO_URI=mongodb://localhost:27017/hackamined
JWT_SECRET_KEY=replace-with-a-long-random-string

# Cloudinary — uploaded files & profile pictures
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Python backend (backend_ai/) ─────────────────────────────────────────────
# Groq is the primary LLM provider for all 4 sub-routers.
GROQ_API_KEY=

# Optional — used by file-editor agent if Groq fails over.
OPENAI_API_KEY=

# LaTeX converter model (chatbot pipeline). Options seen in the codebase:
#   openai/gpt-oss-120b                           (default, higher quality)
#   meta-llama/llama-4-maverick-17b-128e-instruct (faster, cheaper)
LATEX_MODEL=openai/gpt-oss-120b

# Deep-scan defaults
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Raises GitHub API rate limit for readme-gen from 60 → 5000 req/hr.
GITHUB_TOKEN=

# Shared JWT — must match the Express JWT_SECRET_KEY above so Python services
# verify tokens Express signed. REQUIRE_AUTH=true → fail-closed in prod;
# default false lets anonymous calls through during rollout.
REQUIRE_AUTH=false

# Bind address for the unified Python service.
BACKEND_AI_HOST=127.0.0.1
BACKEND_AI_PORT=8000

# Note (Phase E.2): routing to the backends is done by NGINX (nginx/default.conf),
# not by Express. There is no AI_SERVICE_URL anymore — NGINX reaches FastAPI at
# backend_ai:8000 and Express at backend:3000 over the internal Docker network.

# ── Optional: imageVideo/ research spike (Lightricks LTX-2) ──────────────────
LTX_API_KEY=
VIDEO_MODEL=ltx-2-fast
VIDEO_RESOLUTION=1920x1080
VIDEO_DURATION=8
VIDEO_FPS=25
IMAGE_MODEL=ltx-2-fast
IMAGE_RESOLUTION=1920x1080

# ── Frontend (frontend/, Vite) ───────────────────────────────────────────────
# Single public origin — the NGINX proxy. Local dev = http://localhost:80;
# production = https://api.yourdomain.com.
VITE_API_URL=http://localhost:80
