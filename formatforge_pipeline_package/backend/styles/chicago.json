{
  "style_name": "Chicago 17th Edition (Notes-Bibliography)",
  "style_id": "chicago",
  "csl_style": "chicago-note-bibliography",

  "page_layout": {
    "margin_top_inches": 1.0,
    "margin_bottom_inches": 1.0,
    "margin_left_inches": 1.0,
    "margin_right_inches": 1.0,
    "page_width_inches": 8.5,
    "page_height_inches": 11.0,
    "orientation": "portrait"
  },

  "default_typography": {
    "font_name": "Times New Roman",
    "font_size_pt": 12.0,
    "line_spacing": 2.0,
    "line_spacing_type": "double",
    "paragraph_alignment": "left",
    "first_line_indent_inches": 0.5,
    "space_after_paragraph_pt": 0.0,
    "space_before_paragraph_pt": 0.0
  },

  "title_page": {
    "required": true,
    "title": {
      "font_size_pt": 12.0,
      "bold": true,
      "italic": false,
      "alignment": "center",
      "position": "approximately one-third down from top"
    },
    "author_name": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center",
      "position": "below the title, centered"
    },
    "affiliation": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center"
    },
    "course_info": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center"
    },
    "instructor": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center"
    },
    "date": {
      "font_size_pt": 12.0,
      "bold": false,
      "italic": false,
      "alignment": "center",
      "position": "near bottom of title page"
    }
  },

  "abstract": {
    "label": "Abstract",
    "label_bold": true,
    "label_alignment": "center",
    "paragraph_indent": false,
    "max_words": 300,
    "keywords_label": "Keywords:",
    "keywords_italic": true,
    "keywords_indent": true
  },

  "headings": {
    "level_1": {
      "alignment": "center",
      "bold": true,
      "italic": false,
      "font_size_pt": 12.0,
      "case": "title_case",
      "standalone_line": true,
      "ends_with_period": false,
      "indent_inches": null,
      "description": "Centered, Bold, Title Case"
    },
    "level_2": {
      "alignment": "center",
      "bold": false,
      "italic": true,
      "font_size_pt": 12.0,
      "case": "title_case",
      "standalone_line": true,
      "ends_with_period": false,
      "indent_inches": null,
      "description": "Centered, Italic, Title Case"
    },
    "level_3": {
      "alignment": "left",
      "bold": true,
      "italic": false,
      "font_size_pt": 12.0,
      "case": "title_case",
      "standalone_line": true,
      "ends_with_period": false,
      "indent_inches": null,
      "description": "Flush Left, Bold, Title Case"
    },
    "level_4": {
      "alignment": "left",
      "bold": false,
      "italic": true,
      "font_size_pt": 12.0,
      "case": "sentence_case",
      "standalone_line": true,
      "ends_with_period": false,
      "indent_inches": null,
      "description": "Flush Left, Italic, Sentence Case"
    },
    "level_5": {
      "alignment": "left",
      "bold": false,
      "italic": false,
      "font_size_pt": 12.0,
      "case": "sentence_case",
      "standalone_line": false,
      "ends_with_period": true,
      "indent_inches": null,
      "description": "Run-in, Regular, Sentence Case, Period."
    }
  },

  "running_head": {
    "enabled": false,
    "content": "",
    "alignment": "right",
    "page_number_alignment": "right",
    "font_size_pt": 12.0,
    "all_caps": false,
    "max_characters": 50
  },

  "references": {
    "section_label": "Bibliography",
    "label_bold": true,
    "label_alignment": "center",
    "entry_indent_type": "hanging",
    "hanging_indent_inches": 0.5,
    "order": "alphabetical_by_first_author",
    "line_spacing": 2.0,
    "csl_style_name": "chicago-note-bibliography"
  },

  "tables": {
    "number_label": "Table",
    "number_bold": false,
    "number_italic": false,
    "title_italic": true,
    "title_below_number": true,
    "note_prefix": "Source:",
    "note_italic_prefix": true,
    "horizontal_lines_only": true
  },

  "figures": {
    "number_label": "Figure",
    "number_bold": false,
    "number_italic": true,
    "title_italic": true,
    "title_below_number": true,
    "note_prefix": "Source:",
    "note_italic_prefix": true
  },

  "in_text_citations": {
    "style": "note",
    "parenthetical_format": "Footnote/Endnote",
    "narrative_format": "Footnote/Endnote",
    "et_al_threshold": 4,
    "ampersand_in_parenthetical": false,
    "and_in_narrative": true
  }
}
