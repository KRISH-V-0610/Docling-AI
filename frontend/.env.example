# =====================================================================
# Frontend env overrides (Vite). Copy to frontend/.env.local for local dev,
# or set in the build/deploy environment for prod.
#
# After Phase 2.5 consolidation there are only two backends total, so only
# two overrides exist. Leave either blank to use the defaults shown below.
# Read by frontend/src/config/api.js.
# =====================================================================

# Express backend — auth, projects, files, LaTeX compile proxy
VITE_EXPRESS_URL=http://localhost:3000

# Unified Python AI service — chatbot, reconstruct, deep-scan, file-editor,
# README generator (all under one process).
VITE_PYTHON_AI_URL=http://127.0.0.1:8000
